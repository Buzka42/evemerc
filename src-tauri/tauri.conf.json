{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EVEMerc Desktop",
  "version": "0.1.0",
  "identifier": "com.evemerc.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EVEMerc Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost https: wss: ws: http://localhost:* http://127.0.0.1:*",
        "img-src": "'self' asset: http://asset.localhost blob: data: https:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["evemerc"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
